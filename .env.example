# - GovNotify Environment Variables -
APP_NAME=govnotify
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=generate-a-long-random-string-here
APP_HOST=0.0.0.0
APP_PORT=8000
DOMAIN_NAME=your-domain.com

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=govnotify
DB_USER=govnotify
DB_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql+asyncpg://govnotify:your-secure-password-here@postgres:5432/govnotify

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=govnotify_chunks

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ENABLE_LLM=true
DISABLE_PADDLEOCR=false

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Delivery
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=

# Crawling
CRAWL_DEFAULT_RATE_LIMIT_RPM=30
CRAWL_USER_AGENT=GovNotify/1.0 (government notification aggregator)
CRAWL_RESPECT_ROBOTS_TXT=true

# RAG
RAG_TOP_K_RETRIEVAL=50
RAG_TOP_K_RERANK=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_SIMILARITY_THRESHOLD=0.3

# Auth
JWT_SECRET_KEY=generate-another-long-random-string-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
